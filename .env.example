# Dakota Analytics Technical Assessment
# Copy to .env and configure with your values

# Postgres container settings (used by docker-compose postgres service)
POSTGRES_USER=energy_user
POSTGRES_PASSWORD=energy_password
POSTGRES_DB=energy_analytics

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=energy_analytics
DB_USER=energy_user
DB_PASSWORD=energy_password

# API database connection string (used by docker-compose api service)
DATABASE_URL=postgresql://energy_user:energy_password@postgres:5432/energy_analytics

API_BASE_URL=http://api:8000
EIA_API_KEY=bgYUdcNb4ZabkgPgMVFB0tbbahaf80nZygceUoYk
EIA_BASE_URL=https://api.eia.gov/v2/petroleum/pri/gnd/

# Ingestion runtime tuning
BATCH_SIZE=100
MAX_RETRIES=3
RETRY_DELAY=5
REQUEST_TIMEOUT=30

